{
  "name": "work4me-bridge",
  "displayName": "Work4Me Bridge",
  "description": "WebSocket bridge for Work4Me desktop agent",
  "version": "0.4.0",
  "publisher": "work4me",
  "license": "MIT",
  "engines": { "vscode": "^1.74.0" },
  "extensionKind": ["ui"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [{
      "command": "work4me.status",
      "title": "Work4Me: Connection Status"
    }]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "vscode:prepublish": "npm run package",
    "compile:types": "tsc --noEmit",
    "vsix": "npm run package && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.5.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0",
    "ws": "^8.14.0"
  }
}
